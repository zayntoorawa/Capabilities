<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>COSMOS — An Interactive Experience</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Crimson+Pro:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --void: #03020a;
    --deep: #0a0818;
    --nebula-1: #ff2d55;
    --nebula-2: #bf5af2;
    --nebula-3: #0af5f5;
    --nebula-4: #ffcc00;
    --nebula-5: #30d158;
    --star: #ffffff;
    --dim: rgba(255,255,255,0.4);
    --font-display: 'Bebas Neue', sans-serif;
    --font-mono: 'Space Mono', monospace;
    --font-body: 'Crimson Pro', serif;
  }

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
background: var(–void);
color: var(–star);
font-family: var(–font-body);
overflow-x: hidden;
cursor: none;
}

/* === CUSTOM CURSOR === */
#cursor {
position: fixed;
width: 12px; height: 12px;
background: var(–nebula-3);
border-radius: 50%;
pointer-events: none;
z-index: 9999;
transform: translate(-50%,-50%);
transition: transform 0.1s, width 0.2s, height 0.2s, background 0.2s;
mix-blend-mode: screen;
}
#cursor-ring {
position: fixed;
width: 40px; height: 40px;
border: 1px solid rgba(10,245,245,0.5);
border-radius: 50%;
pointer-events: none;
z-index: 9998;
transform: translate(-50%,-50%);
transition: transform 0.15s ease-out, width 0.3s, height 0.3s, border-color 0.3s;
}
body:hover #cursor { opacity: 1; }

/* === CANVAS BACKGROUND === */
#star-canvas {
position: fixed;
top: 0; left: 0;
width: 100%; height: 100%;
z-index: 0;
pointer-events: none;
}

/* === SECTIONS === */
section {
position: relative;
z-index: 1;
min-height: 100vh;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
padding: 80px 40px;
}

/* === HERO === */
#hero {
overflow: hidden;
text-align: center;
}

.hero-eyebrow {
font-family: var(–font-mono);
font-size: 11px;
letter-spacing: 0.4em;
color: var(–nebula-3);
text-transform: uppercase;
margin-bottom: 24px;
opacity: 0;
animation: fadeUp 1s 0.2s forwards;
}

.hero-title {
font-family: var(–font-display);
font-size: clamp(80px, 18vw, 220px);
line-height: 0.88;
letter-spacing: -0.02em;
background: linear-gradient(135deg, #fff 0%, #a0f0ff 40%, #bf5af2 70%, #ff2d55 100%);
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
background-clip: text;
opacity: 0;
animation: fadeUp 1.2s 0.4s forwards;
user-select: none;
}

.hero-subtitle {
font-family: var(–font-body);
font-style: italic;
font-size: clamp(16px, 2.5vw, 26px);
color: var(–dim);
margin-top: 24px;
max-width: 560px;
line-height: 1.5;
opacity: 0;
animation: fadeUp 1s 0.8s forwards;
}

.hero-cta {
margin-top: 48px;
display: flex;
gap: 16px;
flex-wrap: wrap;
justify-content: center;
opacity: 0;
animation: fadeUp 1s 1.1s forwards;
}

.btn {
font-family: var(–font-mono);
font-size: 11px;
letter-spacing: 0.2em;
text-transform: uppercase;
text-decoration: none;
padding: 14px 32px;
border: 1px solid;
border-radius: 2px;
cursor: none;
transition: all 0.3s;
position: relative;
overflow: hidden;
}
.btn::before {
content: ‘’;
position: absolute;
inset: 0;
opacity: 0;
transition: opacity 0.3s;
}
.btn:hover::before { opacity: 1; }
.btn-primary {
border-color: var(–nebula-3);
color: var(–void);
background: var(–nebula-3);
}
.btn-primary:hover {
background: transparent;
color: var(–nebula-3);
}
.btn-ghost {
border-color: rgba(255,255,255,0.3);
color: var(–star);
background: transparent;
}
.btn-ghost:hover {
border-color: var(–star);
background: rgba(255,255,255,0.05);
}

.scroll-hint {
position: absolute;
bottom: 40px;
left: 50%;
transform: translateX(-50%);
display: flex;
flex-direction: column;
align-items: center;
gap: 8px;
opacity: 0;
animation: fadeUp 1s 1.8s forwards;
}
.scroll-hint span {
font-family: var(–font-mono);
font-size: 9px;
letter-spacing: 0.3em;
color: var(–dim);
text-transform: uppercase;
}
.scroll-line {
width: 1px;
height: 60px;
background: linear-gradient(to bottom, var(–nebula-2), transparent);
animation: scrollPulse 2s infinite;
}

/* === GRAVITY SECTION === */
#gravity {
background: radial-gradient(ellipse at center, rgba(191,90,242,0.08) 0%, transparent 70%);
}

.section-label {
font-family: var(–font-mono);
font-size: 10px;
letter-spacing: 0.5em;
color: var(–nebula-2);
text-transform: uppercase;
margin-bottom: 16px;
}

.section-title {
font-family: var(–font-display);
font-size: clamp(48px, 8vw, 100px);
line-height: 1;
margin-bottom: 20px;
text-align: center;
}

.section-desc {
font-family: var(–font-body);
font-size: 18px;
font-style: italic;
color: var(–dim);
text-align: center;
max-width: 500px;
margin-bottom: 48px;
}

#gravity-canvas {
width: min(600px, 90vw);
height: min(400px, 55vw);
border: 1px solid rgba(191,90,242,0.3);
border-radius: 4px;
cursor: none;
background: rgba(10,8,24,0.8);
backdrop-filter: blur(10px);
position: relative;
}

.gravity-hint {
font-family: var(–font-mono);
font-size: 10px;
color: var(–dim);
margin-top: 16px;
letter-spacing: 0.15em;
text-align: center;
}

/* === AUDIO SECTION === */
#audio-section {
background: radial-gradient(ellipse at center, rgba(255,45,85,0.08) 0%, transparent 70%);
}

#visualizer-canvas {
width: min(700px, 95vw);
height: 220px;
border: 1px solid rgba(255,45,85,0.3);
border-radius: 4px;
background: rgba(10,8,24,0.9);
margin-bottom: 32px;
}

.audio-controls {
display: flex;
flex-wrap: wrap;
gap: 12px;
align-items: center;
justify-content: center;
}

.synth-key {
font-family: var(–font-mono);
font-size: 10px;
letter-spacing: 0.1em;
padding: 10px 16px;
border: 1px solid rgba(255,45,85,0.4);
background: transparent;
color: var(–star);
cursor: none;
transition: all 0.15s;
border-radius: 2px;
min-width: 50px;
text-align: center;
}
.synth-key:hover, .synth-key.active {
background: var(–nebula-1);
border-color: var(–nebula-1);
color: var(–void);
transform: translateY(-2px);
box-shadow: 0 4px 20px rgba(255,45,85,0.4);
}

.waveform-selector {
display: flex;
gap: 8px;
margin-top: 16px;
flex-wrap: wrap;
justify-content: center;
}
.wave-btn {
font-family: var(–font-mono);
font-size: 9px;
letter-spacing: 0.2em;
padding: 6px 14px;
border: 1px solid rgba(255,255,255,0.2);
background: transparent;
color: var(–dim);
cursor: none;
transition: all 0.2s;
border-radius: 1px;
text-transform: uppercase;
}
.wave-btn.active, .wave-btn:hover {
border-color: var(–nebula-4);
color: var(–nebula-4);
}

/* === CONSTELLATION === */
#constellation {
background: radial-gradient(ellipse at center, rgba(10,245,245,0.05) 0%, transparent 70%);
}

#constellation-canvas {
width: min(700px, 95vw);
height: min(500px, 70vw);
cursor: none;
}

.constellation-controls {
display: flex;
gap: 12px;
margin-top: 20px;
flex-wrap: wrap;
justify-content: center;
}

/* === TEXT MORPH === */
#morph-section {
background: radial-gradient(ellipse at center, rgba(48,209,88,0.06) 0%, transparent 70%);
text-align: center;
}

#morph-word {
font-family: var(–font-display);
font-size: clamp(60px, 14vw, 180px);
line-height: 1;
background: linear-gradient(135deg, var(–nebula-5), var(–nebula-3));
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
background-clip: text;
min-height: 1.1em;
display: flex;
align-items: center;
justify-content: center;
cursor: none;
}

/* === PARTICLE TRAIL === */
#trail-section {
background: radial-gradient(ellipse at center, rgba(255,204,0,0.06) 0%, transparent 70%);
}

#trail-canvas {
width: min(700px, 95vw);
height: min(450px, 65vw);
border: 1px solid rgba(255,204,0,0.2);
border-radius: 4px;
background: rgba(3,2,10,0.95);
cursor: none;
}

.trail-options {
display: flex;
gap: 12px;
margin-top: 20px;
flex-wrap: wrap;
justify-content: center;
}

.trail-btn {
font-family: var(–font-mono);
font-size: 10px;
letter-spacing: 0.2em;
padding: 8px 18px;
border: 1px solid rgba(255,204,0,0.3);
background: transparent;
color: var(–dim);
cursor: none;
transition: all 0.2s;
border-radius: 2px;
text-transform: uppercase;
}
.trail-btn.active, .trail-btn:hover {
border-color: var(–nebula-4);
color: var(–nebula-4);
background: rgba(255,204,0,0.05);
}

/* === NAV === */
nav {
position: fixed;
top: 0; left: 0; right: 0;
z-index: 100;
padding: 20px 40px;
display: flex;
justify-content: space-between;
align-items: center;
background: linear-gradient(to bottom, rgba(3,2,10,0.9), transparent);
backdrop-filter: blur(4px);
}

.nav-logo {
font-family: var(–font-display);
font-size: 24px;
letter-spacing: 0.1em;
color: var(–star);
text-decoration: none;
cursor: none;
background: linear-gradient(90deg, var(–nebula-3), var(–nebula-2));
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
background-clip: text;
}

.nav-links {
display: flex;
gap: 32px;
list-style: none;
}

.nav-links a {
font-family: var(–font-mono);
font-size: 10px;
letter-spacing: 0.25em;
text-transform: uppercase;
color: var(–dim);
text-decoration: none;
cursor: none;
transition: color 0.2s;
}
.nav-links a:hover { color: var(–star); }

/* === FOOTER === */
footer {
position: relative;
z-index: 1;
padding: 60px 40px;
text-align: center;
border-top: 1px solid rgba(255,255,255,0.05);
}
footer p {
font-family: var(–font-mono);
font-size: 10px;
letter-spacing: 0.3em;
color: rgba(255,255,255,0.2);
text-transform: uppercase;
}

/* === KEYFRAMES === */
@keyframes fadeUp {
from { opacity: 0; transform: translateY(30px); }
to { opacity: 1; transform: translateY(0); }
}

@keyframes scrollPulse {
0%, 100% { opacity: 0.3; transform: scaleY(1); }
50% { opacity: 1; transform: scaleY(1.1); }
}

/* === RESPONSIVE === */
@media (max-width: 600px) {
nav { padding: 16px 20px; }
.nav-links { gap: 16px; }
section { padding: 60px 20px; }
}

/* glitch effect for morph */
@keyframes glitch {
0% { clip-path: inset(0 0 95% 0); transform: translate(-3px,0); }
20% { clip-path: inset(40% 0 50% 0); transform: translate(3px,0); }
40% { clip-path: inset(70% 0 15% 0); transform: translate(-2px,0); }
60% { clip-path: inset(20% 0 65% 0); transform: translate(4px,0); }
80% { clip-path: inset(85% 0 5% 0); transform: translate(-3px,0); }
100% { clip-path: inset(0 0 95% 0); transform: translate(0,0); }
}

.section-header {
display: flex;
flex-direction: column;
align-items: center;
margin-bottom: 48px;
}

.divider {
width: 60px;
height: 1px;
background: linear-gradient(90deg, transparent, var(–nebula-2), transparent);
margin: 16px auto;
}

/* Tooltip-style tag */
.tag {
font-family: var(–font-mono);
font-size: 9px;
letter-spacing: 0.2em;
padding: 4px 10px;
border-radius: 1px;
text-transform: uppercase;
display: inline-block;
margin: 4px;
}
.tag-cyan { background: rgba(10,245,245,0.1); color: var(–nebula-3); border: 1px solid rgba(10,245,245,0.3); }
.tag-purple { background: rgba(191,90,242,0.1); color: var(–nebula-2); border: 1px solid rgba(191,90,242,0.3); }
.tag-red { background: rgba(255,45,85,0.1); color: var(–nebula-1); border: 1px solid rgba(255,45,85,0.3); }
.tag-gold { background: rgba(255,204,0,0.1); color: var(–nebula-4); border: 1px solid rgba(255,204,0,0.3); }
.tag-green { background: rgba(48,209,88,0.1); color: var(–nebula-5); border: 1px solid rgba(48,209,88,0.3); }

#fps {
position: fixed;
bottom: 16px; right: 16px;
font-family: var(–font-mono);
font-size: 9px;
color: rgba(255,255,255,0.15);
z-index: 200;
letter-spacing: 0.2em;
}
</style>

</head>
<body>

<canvas id="star-canvas"></canvas>

<div id="cursor"></div>
<div id="cursor-ring"></div>
<div id="fps">00 FPS</div>

<nav>
  <a href="#hero" class="nav-logo">COSMOS</a>
  <ul class="nav-links">
    <li><a href="#gravity">Gravity</a></li>
    <li><a href="#audio-section">Synth</a></li>
    <li><a href="#constellation">Stars</a></li>
    <li><a href="#morph-section">Morph</a></li>
    <li><a href="#trail-section">Trail</a></li>
  </ul>
</nav>

<!-- HERO -->

<section id="hero">
  <p class="hero-eyebrow">An interactive experience — crafted by Claude</p>
  <h1 class="hero-title">COSMOS</h1>
  <p class="hero-subtitle">A playground at the edge of what's possible in a browser. Touch everything. Break nothing. Discover the universe.</p>
  <div class="hero-cta">
    <a href="#gravity" class="btn btn-primary">Begin the Journey</a>
    <a href="#trail-section" class="btn btn-ghost">Jump to Canvas</a>
  </div>
  <div class="scroll-hint">
    <div class="scroll-line"></div>
    <span>Scroll to explore</span>
  </div>
</section>

<!-- GRAVITY SIMULATION -->

<section id="gravity">
  <div class="section-header">
    <span class="section-label">01 — Physics</span>
    <h2 class="section-title">Gravity Well</h2>
    <div class="divider"></div>
    <p class="section-desc">Click to spawn planets. Watch them orbit, collide, and merge in real-time Newtonian physics.</p>
    <div>
      <span class="tag tag-purple">Click to spawn</span>
      <span class="tag tag-purple">Drag to fling</span>
      <span class="tag tag-purple">Right-click for black hole</span>
    </div>
  </div>
  <canvas id="gravity-canvas"></canvas>
  <p class="gravity-hint">Scroll to zoom · Double-click to clear · Bodies merge on collision</p>
</section>

<!-- SYNTH VISUALIZER -->

<section id="audio-section">
  <div class="section-header">
    <span class="section-label">02 — Audio</span>
    <h2 class="section-title">Cosmic Synth</h2>
    <div class="divider"></div>
    <p class="section-desc">Play the keyboard to generate tones. Watch the waveform erupt in real time.</p>
    <div>
      <span class="tag tag-red">Click buttons or press keys A–K</span>
    </div>
  </div>
  <canvas id="visualizer-canvas"></canvas>
  <div class="audio-controls" id="synth-keys"></div>
  <div class="waveform-selector">
    <button class="wave-btn active" data-wave="sine">Sine</button>
    <button class="wave-btn" data-wave="square">Square</button>
    <button class="wave-btn" data-wave="sawtooth">Sawtooth</button>
    <button class="wave-btn" data-wave="triangle">Triangle</button>
  </div>
</section>

<!-- CONSTELLATION BUILDER -->

<section id="constellation">
  <div class="section-header">
    <span class="section-label">03 — Generative</span>
    <h2 class="section-title">Constellation</h2>
    <div class="divider"></div>
    <p class="section-desc">Place stars by clicking. Watch them self-connect based on proximity and gravity.</p>
    <div>
      <span class="tag tag-cyan">Click to place star</span>
      <span class="tag tag-cyan">Stars auto-connect</span>
    </div>
  </div>
  <canvas id="constellation-canvas"></canvas>
  <div class="constellation-controls">
    <button class="btn btn-ghost" id="constellation-clear">Clear Sky</button>
    <button class="btn btn-ghost" id="constellation-auto">Auto Generate</button>
    <button class="btn btn-ghost" id="constellation-lines">Toggle Lines</button>
  </div>
</section>

<!-- TEXT MORPH -->

<section id="morph-section">
  <div class="section-header">
    <span class="section-label">04 — Typography</span>
    <h2 class="section-title">Word Morphing</h2>
    <div class="divider"></div>
    <p class="section-desc">Words dissolve into particles and reform. Click to trigger. Reality is just letters rearranging.</p>
  </div>
  <div id="morph-word">COSMOS</div>
  <div style="margin-top:32px;display:flex;gap:12px;flex-wrap:wrap;justify-content:center;">
    <button class="btn btn-ghost" id="morph-btn">Morph Word</button>
    <button class="btn btn-ghost" id="morph-type-btn">Change Type</button>
  </div>
</section>

<!-- PARTICLE TRAIL -->

<section id="trail-section">
  <div class="section-header">
    <span class="section-label">05 — Canvas Art</span>
    <h2 class="section-title">Particle Trail</h2>
    <div class="divider"></div>
    <p class="section-desc">Paint the void. Each movement spawns a universe of particles that drift and fade.</p>
    <div>
      <span class="tag tag-gold">Move mouse to paint</span>
      <span class="tag tag-gold">Click to burst</span>
    </div>
  </div>
  <canvas id="trail-canvas"></canvas>
  <div class="trail-options">
    <button class="trail-btn active" data-mode="nebula">Nebula</button>
    <button class="trail-btn" data-mode="fire">Fire</button>
    <button class="trail-btn" data-mode="ice">Ice</button>
    <button class="trail-btn" data-mode="electric">Electric</button>
    <button class="trail-btn" data-mode="rainbow">Rainbow</button>
    <button class="trail-btn" id="trail-clear-btn">Clear</button>
  </div>
</section>

<footer>
  <p>COSMOS — Built with pure HTML, CSS & JavaScript — No frameworks, no libraries, just craft</p>
  <p style="margin-top:8px;">Move. Click. Explore. The universe responds.</p>
</footer>

<script>
// ============================================================
//  UTILITIES
// ============================================================
const $ = (s) => document.querySelector(s);
const $$ = (s) => document.querySelectorAll(s);
let mouseX = window.innerWidth/2, mouseY = window.innerHeight/2;
let fpsCount = 0, lastFpsTime = performance.now();

// FPS counter
function updateFPS() {
  fpsCount++;
  const now = performance.now();
  if (now - lastFpsTime >= 1000) {
    $('#fps').textContent = String(fpsCount).padStart(2,'0') + ' FPS';
    fpsCount = 0;
    lastFpsTime = now;
  }
}

// ============================================================
//  CUSTOM CURSOR
// ============================================================
const cursor = $('#cursor');
const ring = $('#cursor-ring');
let cx = mouseX, cy = mouseY, rx = mouseX, ry = mouseY;

document.addEventListener('mousemove', (e) => {
  mouseX = e.clientX; mouseY = e.clientY;
});

document.addEventListener('mousedown', () => {
  cursor.style.width = '20px';
  cursor.style.height = '20px';
  ring.style.width = '60px';
  ring.style.height = '60px';
  ring.style.borderColor = 'rgba(255,45,85,0.8)';
});
document.addEventListener('mouseup', () => {
  cursor.style.width = '12px';
  cursor.style.height = '12px';
  ring.style.width = '40px';
  ring.style.height = '40px';
  ring.style.borderColor = 'rgba(10,245,245,0.5)';
});

(function animCursor() {
  cx += (mouseX - cx) * 0.15;
  cy += (mouseY - cy) * 0.15;
  rx += (mouseX - rx) * 0.08;
  ry += (mouseY - ry) * 0.08;
  cursor.style.left = mouseX + 'px';
  cursor.style.top = mouseY + 'px';
  ring.style.left = rx + 'px';
  ring.style.top = ry + 'px';
  requestAnimationFrame(animCursor);
})();

// ============================================================
//  STAR FIELD
// ============================================================
(function() {
  const canvas = $('#star-canvas');
  const ctx = canvas.getContext('2d');
  let W, H, stars = [];

  function resize() {
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
    stars = Array.from({length: 250}, () => ({
      x: Math.random() * W,
      y: Math.random() * H,
      r: Math.random() * 1.5 + 0.2,
      alpha: Math.random(),
      speed: Math.random() * 0.3 + 0.05,
      twinkle: Math.random() * Math.PI * 2
    }));
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    const t = performance.now() / 1000;
    stars.forEach(s => {
      s.twinkle += s.speed * 0.05;
      const a = s.alpha * (0.6 + 0.4 * Math.sin(s.twinkle));
      ctx.save();
      ctx.globalAlpha = a;
      ctx.fillStyle = '#fff';
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    });
    requestAnimationFrame(draw);
    updateFPS();
  }

  resize();
  draw();
  window.addEventListener('resize', resize);
})();

// ============================================================
//  GRAVITY SIMULATION
// ============================================================
(function() {
  const canvas = $('#gravity-canvas');
  const ctx = canvas.getContext('2d');
  const W = canvas.width = canvas.offsetWidth;
  const H = canvas.height = canvas.offsetHeight;
  
  let bodies = [];
  let dragging = null;
  let dragStart = null;
  let dragCurrent = null;
  let zoom = 1;
  let blackHoles = [];

  const COLORS = ['#ff2d55','#bf5af2','#0af5f5','#ffcc00','#30d158','#ff9f0a','#64d2ff'];

  function randomColor() { return COLORS[Math.floor(Math.random()*COLORS.length)]; }

  function spawnBody(x, y, vx=0, vy=0, mass=null) {
    const m = mass || (Math.random() * 15 + 5);
    bodies.push({
      x, y,
      vx: vx + (Math.random()-0.5)*0.5,
      vy: vy + (Math.random()-0.5)*0.5,
      mass: m,
      r: Math.cbrt(m) * 3,
      color: randomColor(),
      trail: [],
      dead: false
    });
  }

  // Seed some initial bodies
  for (let i = 0; i < 6; i++) {
    spawnBody(W/2 + (Math.random()-0.5)*200, H/2 + (Math.random()-0.5)*200);
  }
  // Central attractor
  blackHoles.push({ x: W/2, y: H/2, mass: 500, r: 10 });

  canvas.addEventListener('click', (e) => {
    if (dragging) return;
    const rect = canvas.getBoundingClientRect();
    spawnBody(e.clientX - rect.left, e.clientY - rect.top);
  });

  canvas.addEventListener('contextmenu', (e) => {
    e.preventDefault();
    const rect = canvas.getBoundingClientRect();
    blackHoles.push({
      x: e.clientX - rect.left,
      y: e.clientY - rect.top,
      mass: 300,
      r: 8,
      temp: true
    });
    setTimeout(() => { blackHoles = blackHoles.filter(b => !b.temp); }, 5000);
  });

  canvas.addEventListener('dblclick', (e) => {
    bodies = [];
    blackHoles = [{ x: W/2, y: H/2, mass: 500, r: 10 }];
  });

  canvas.addEventListener('wheel', (e) => {
    e.preventDefault();
    zoom = Math.max(0.4, Math.min(2.5, zoom + (e.deltaY > 0 ? -0.1 : 0.1)));
  }, { passive: false });

  function update() {
    const G = 0.8;
    const sources = [...blackHoles];

    for (let i = 0; i < bodies.length; i++) {
      const b = bodies[i];
      // Attract to black holes
      for (const bh of sources) {
        const dx = bh.x - b.x, dy = bh.y - b.y;
        const distSq = dx*dx + dy*dy;
        const dist = Math.sqrt(distSq);
        if (dist < bh.r + b.r) { b.dead = true; continue; }
        const f = G * bh.mass / distSq;
        b.vx += f * dx / dist;
        b.vy += f * dy / dist;
      }
      // Body-body interactions
      for (let j = i+1; j < bodies.length; j++) {
        const c = bodies[j];
        const dx = c.x - b.x, dy = c.y - b.y;
        const distSq = dx*dx + dy*dy;
        const dist = Math.sqrt(distSq) || 0.1;
        if (dist < b.r + c.r) {
          // Merge
          const tm = b.mass + c.mass;
          b.vx = (b.vx*b.mass + c.vx*c.mass) / tm;
          b.vy = (b.vy*b.mass + c.vy*c.mass) / tm;
          b.x = (b.x*b.mass + c.x*c.mass) / tm;
          b.y = (b.y*b.mass + c.y*c.mass) / tm;
          b.mass = tm;
          b.r = Math.cbrt(tm) * 3;
          c.dead = true;
          continue;
        }
        const f = G * b.mass * c.mass / distSq;
        const fx = f * dx / dist, fy = f * dy / dist;
        b.vx += fx / b.mass; b.vy += fy / b.mass;
        c.vx -= fx / c.mass; c.vy -= fy / c.mass;
      }
      // Cap velocity
      const spd = Math.sqrt(b.vx*b.vx + b.vy*b.vy);
      if (spd > 8) { b.vx = b.vx/spd*8; b.vy = b.vy/spd*8; }
      b.x += b.vx; b.y += b.vy;
      // Trail
      b.trail.push({x:b.x, y:b.y});
      if (b.trail.length > 40) b.trail.shift();
      // Bounds
      if (b.x < -50 || b.x > W+50 || b.y < -50 || b.y > H+50) b.dead = true;
    }
    bodies = bodies.filter(b => !b.dead);
    if (bodies.length > 50) bodies.splice(0, bodies.length-50);
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    ctx.save();
    ctx.translate(W/2, H/2);
    ctx.scale(zoom, zoom);
    ctx.translate(-W/2, -H/2);

    // Draw black holes
    for (const bh of blackHoles) {
      const grd = ctx.createRadialGradient(bh.x, bh.y, 0, bh.x, bh.y, bh.r*8);
      grd.addColorStop(0, 'rgba(0,0,0,1)');
      grd.addColorStop(0.3, 'rgba(191,90,242,0.4)');
      grd.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = grd;
      ctx.beginPath();
      ctx.arc(bh.x, bh.y, bh.r*8, 0, Math.PI*2);
      ctx.fill();
      ctx.fillStyle = '#000';
      ctx.beginPath();
      ctx.arc(bh.x, bh.y, bh.r, 0, Math.PI*2);
      ctx.fill();
    }

    // Draw bodies
    for (const b of bodies) {
      // Trail
      if (b.trail.length > 2) {
        ctx.beginPath();
        ctx.moveTo(b.trail[0].x, b.trail[0].y);
        for (let i = 1; i < b.trail.length; i++) {
          ctx.lineTo(b.trail[i].x, b.trail[i].y);
          ctx.globalAlpha = (i / b.trail.length) * 0.4;
          ctx.strokeStyle = b.color;
          ctx.lineWidth = 1;
        }
        ctx.stroke();
        ctx.globalAlpha = 1;
      }
      // Glow
      const grd = ctx.createRadialGradient(b.x, b.y, 0, b.x, b.y, b.r*2.5);
      grd.addColorStop(0, b.color);
      grd.addColorStop(0.5, b.color + '88');
      grd.addColorStop(1, 'transparent');
      ctx.fillStyle = grd;
      ctx.beginPath();
      ctx.arc(b.x, b.y, b.r*2.5, 0, Math.PI*2);
      ctx.fill();
      ctx.fillStyle = b.color;
      ctx.beginPath();
      ctx.arc(b.x, b.y, b.r, 0, Math.PI*2);
      ctx.fill();
    }

    ctx.restore();
  }

  function loop() {
    update();
    draw();
    requestAnimationFrame(loop);
  }
  loop();
})();

// ============================================================
//  SYNTH VISUALIZER
// ============================================================
(function() {
  let audioCtx = null;
  let analyser = null;
  let activeNodes = {};
  let waveType = 'sine';
  const canvas = $('#visualizer-canvas');
  const ctx = canvas.getContext('2d');
  canvas.width = canvas.offsetWidth;
  canvas.height = canvas.offsetHeight;
  const W = canvas.width, H = canvas.height;

  const NOTES = [
    { label: 'C', freq: 261.63, key: 'a' },
    { label: 'D', freq: 293.66, key: 's' },
    { label: 'E', freq: 329.63, key: 'd' },
    { label: 'F', freq: 349.23, key: 'f' },
    { label: 'G', freq: 392.00, key: 'g' },
    { label: 'A', freq: 440.00, key: 'h' },
    { label: 'B', freq: 493.88, key: 'j' },
    { label: 'C5', freq: 523.25, key: 'k' },
  ];

  function initAudio() {
    if (audioCtx) return;
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    analyser = audioCtx.createAnalyser();
    analyser.fftSize = 512;
    analyser.connect(audioCtx.destination);
  }

  function playNote(freq, id) {
    initAudio();
    if (activeNodes[id]) return;
    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();
    osc.type = waveType;
    osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
    gain.gain.setValueAtTime(0, audioCtx.currentTime);
    gain.gain.linearRampToValueAtTime(0.3, audioCtx.currentTime + 0.01);
    osc.connect(gain);
    gain.connect(analyser);
    osc.start();
    activeNodes[id] = { osc, gain };
  }

  function stopNote(id) {
    if (!activeNodes[id]) return;
    const { osc, gain } = activeNodes[id];
    gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.15);
    osc.stop(audioCtx.currentTime + 0.15);
    delete activeNodes[id];
  }

  // Build keys
  const keyContainer = $('#synth-keys');
  NOTES.forEach(note => {
    const btn = document.createElement('button');
    btn.className = 'synth-key';
    btn.textContent = note.label + '\n[' + note.key.toUpperCase() + ']';
    btn.style.whiteSpace = 'pre';
    btn.dataset.id = note.key;
    btn.addEventListener('mousedown', () => { playNote(note.freq, note.key); btn.classList.add('active'); });
    btn.addEventListener('mouseup', () => { stopNote(note.key); btn.classList.remove('active'); });
    btn.addEventListener('mouseleave', () => { stopNote(note.key); btn.classList.remove('active'); });
    keyContainer.appendChild(btn);
  });

  document.addEventListener('keydown', (e) => {
    const note = NOTES.find(n => n.key === e.key.toLowerCase());
    if (note) {
      playNote(note.freq, note.key);
      const btn = keyContainer.querySelector(`[data-id="${note.key}"]`);
      if (btn) btn.classList.add('active');
    }
  });
  document.addEventListener('keyup', (e) => {
    const note = NOTES.find(n => n.key === e.key.toLowerCase());
    if (note) {
      stopNote(note.key);
      const btn = keyContainer.querySelector(`[data-id="${note.key}"]`);
      if (btn) btn.classList.remove('active');
    }
  });

  $$('.wave-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      $$('.wave-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      waveType = btn.dataset.wave;
    });
  });

  let hue = 0;
  function drawViz() {
    ctx.fillStyle = 'rgba(10,8,24,0.3)';
    ctx.fillRect(0, 0, W, H);

    if (!analyser) {
      // Draw idle waveform
      ctx.strokeStyle = 'rgba(255,45,85,0.3)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      for (let x = 0; x < W; x++) {
        const y = H/2 + Math.sin(x * 0.02 + performance.now()*0.001) * 4;
        x === 0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
      }
      ctx.stroke();
      requestAnimationFrame(drawViz);
      return;
    }

    const dataArr = new Uint8Array(analyser.frequencyBinCount);
    analyser.getByteFrequencyData(dataArr);
    const timeArr = new Uint8Array(analyser.frequencyBinCount);
    analyser.getByteTimeDomainData(timeArr);

    hue = (hue + 0.5) % 360;

    // Frequency bars
    const barW = W / dataArr.length * 2;
    for (let i = 0; i < dataArr.length; i++) {
      const v = dataArr[i] / 255;
      const barH = v * H * 0.7;
      const x = i * barW;
      const grd = ctx.createLinearGradient(x, H, x, H - barH);
      grd.addColorStop(0, `hsla(${(hue + i*2) % 360},100%,60%,0.8)`);
      grd.addColorStop(1, `hsla(${(hue + i*2 + 60) % 360},100%,80%,0.2)`);
      ctx.fillStyle = grd;
      ctx.fillRect(x, H - barH, barW - 1, barH);
    }

    // Waveform overlay
    ctx.strokeStyle = `hsla(${hue},100%,75%,0.9)`;
    ctx.lineWidth = 2;
    ctx.beginPath();
    const sliceW = W / timeArr.length;
    for (let i = 0; i < timeArr.length; i++) {
      const v = timeArr[i] / 128.0;
      const y = (v * H) / 2;
      i === 0 ? ctx.moveTo(0, y) : ctx.lineTo(i * sliceW, y);
    }
    ctx.stroke();

    requestAnimationFrame(drawViz);
  }
  drawViz();
})();

// ============================================================
//  CONSTELLATION
// ============================================================
(function() {
  const canvas = $('#constellation-canvas');
  const ctx = canvas.getContext('2d');
  canvas.width = canvas.offsetWidth;
  canvas.height = canvas.offsetHeight;
  const W = canvas.width, H = canvas.height;

  let stars = [];
  let showLines = true;
  let time = 0;
  const MAX_DIST = 150;

  function addStar(x, y) {
    stars.push({
      x, y,
      r: Math.random() * 3 + 1.5,
      alpha: 0,
      targetAlpha: Math.random() * 0.6 + 0.4,
      pulse: Math.random() * Math.PI * 2,
      speed: Math.random() * 0.02 + 0.01,
      dx: (Math.random()-0.5)*0.3,
      dy: (Math.random()-0.5)*0.3,
      color: `hsl(${180 + Math.random()*80}, 100%, 75%)`
    });
  }

  canvas.addEventListener('click', (e) => {
    const rect = canvas.getBoundingClientRect();
    addStar(e.clientX - rect.left, e.clientY - rect.top);
  });

  $('#constellation-clear').addEventListener('click', () => { stars = []; });

  $('#constellation-auto').addEventListener('click', () => {
    for (let i = 0; i < 8; i++) {
      setTimeout(() => addStar(Math.random()*W*0.8+W*0.1, Math.random()*H*0.8+H*0.1), i*80);
    }
  });

  $('#constellation-lines').addEventListener('click', () => { showLines = !showLines; });

  function draw() {
    ctx.clearRect(0, 0, W, H);
    time += 0.01;

    for (const s of stars) {
      s.alpha = Math.min(s.targetAlpha, s.alpha + 0.03);
      s.pulse += s.speed;
      s.x += s.dx; s.y += s.dy;
      s.x = ((s.x % W) + W) % W;
      s.y = ((s.y % H) + H) % H;
    }

    if (showLines) {
      for (let i = 0; i < stars.length; i++) {
        for (let j = i+1; j < stars.length; j++) {
          const a = stars[i], b = stars[j];
          const dx = a.x-b.x, dy = a.y-b.y;
          const dist = Math.sqrt(dx*dx+dy*dy);
          if (dist < MAX_DIST) {
            const alpha = (1 - dist/MAX_DIST) * 0.5;
            const grd = ctx.createLinearGradient(a.x,a.y,b.x,b.y);
            grd.addColorStop(0, `rgba(10,245,245,${alpha})`);
            grd.addColorStop(1, `rgba(191,90,242,${alpha})`);
            ctx.strokeStyle = grd;
            ctx.lineWidth = (1 - dist/MAX_DIST) * 1.5;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.stroke();
          }
        }
      }
    }

    for (const s of stars) {
      const pAlpha = s.alpha * (0.7 + 0.3 * Math.sin(s.pulse));
      // Glow
      const grd = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, s.r*5);
      grd.addColorStop(0, s.color.replace(')', `, ${pAlpha})`).replace('hsl', 'hsla'));
      grd.addColorStop(1, 'transparent');
      ctx.fillStyle = grd;
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r*5, 0, Math.PI*2);
      ctx.fill();
      // Core
      ctx.fillStyle = `rgba(255,255,255,${pAlpha})`;
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI*2);
      ctx.fill();
    }

    requestAnimationFrame(draw);
  }
  draw();

  // Auto seed
  for (let i = 0; i < 5; i++) {
    addStar(Math.random()*W*0.8+W*0.1, Math.random()*H*0.8+H*0.1);
  }
})();

// ============================================================
//  TEXT MORPH
// ============================================================
(function() {
  const el = $('#morph-word');
  const morphBtn = $('#morph-btn');
  const typeBtn = $('#morph-type-btn');

  const wordSets = [
    ['COSMOS','NEBULA','QUASAR','PULSAR','PHOTON','ENTROPY','VOID'],
    ['CREATE','DESIGN','BUILD','CRAFT','FORGE','SHAPE','MAKE'],
    ['SIGNAL','NOISE','CHAOS','ORDER','BINARY','LOGIC','FLOW'],
  ];
  let setIdx = 0, wordIdx = 0;
  let morphing = false;

  const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&';

  function scramble(from, to, progress) {
    const len = Math.max(from.length, to.length);
    let out = '';
    for (let i = 0; i < len; i++) {
      const p = progress - (i / len) * 0.5;
      if (p >= 1) {
        out += to[i] || '';
      } else if (p > 0) {
        out += chars[Math.floor(Math.random() * chars.length)];
      } else {
        out += from[i] || '';
      }
    }
    return out;
  }

  function morph() {
    if (morphing) return;
    morphing = true;
    const words = wordSets[setIdx];
    const from = words[wordIdx];
    wordIdx = (wordIdx + 1) % words.length;
    const to = words[wordIdx];
    let progress = 0;
    const dur = 800;
    const start = performance.now();

    function step(now) {
      progress = Math.min(1, (now - start) / dur);
      const eased = progress < 0.5 ? 2*progress*progress : -1+(4-2*progress)*progress;
      el.textContent = scramble(from, to, eased * 1.5);
      if (progress < 1) {
        requestAnimationFrame(step);
      } else {
        el.textContent = to;
        morphing = false;
      }
    }
    requestAnimationFrame(step);
  }

  morphBtn.addEventListener('click', morph);
  el.addEventListener('click', morph);

  typeBtn.addEventListener('click', () => {
    setIdx = (setIdx + 1) % wordSets.length;
    wordIdx = 0;
    morph();
  });

  // Auto morph
  setInterval(() => { if (!morphing) morph(); }, 3000);
})();

// ============================================================
//  PARTICLE TRAIL
// ============================================================
(function() {
  const canvas = $('#trail-canvas');
  const ctx = canvas.getContext('2d');
  canvas.width = canvas.offsetWidth;
  canvas.height = canvas.offsetHeight;
  const W = canvas.width, H = canvas.height;

  let particles = [];
  let mode = 'nebula';
  let isOver = false;
  let lx = W/2, ly = H/2;

  const MODES = {
    nebula: () => ({
      hue: 200 + Math.random()*120,
      sat: 100,
      lit: 60,
      vx: (Math.random()-0.5)*3,
      vy: (Math.random()-0.5)*3 - 1,
      life: 80,
      size: Math.random()*4+1,
      decay: 0.015
    }),
    fire: () => ({
      hue: Math.random()*40,
      sat: 100,
      lit: 50+Math.random()*30,
      vx: (Math.random()-0.5)*2,
      vy: -(Math.random()*4+1),
      life: 60,
      size: Math.random()*5+2,
      decay: 0.02
    }),
    ice: () => ({
      hue: 180+Math.random()*30,
      sat: 80,
      lit: 70,
      vx: (Math.random()-0.5)*4,
      vy: (Math.random()-0.5)*2+0.5,
      life: 100,
      size: Math.random()*3+0.5,
      decay: 0.01
    }),
    electric: () => ({
      hue: 60+Math.random()*40,
      sat: 100,
      lit: 80,
      vx: (Math.random()-0.5)*8,
      vy: (Math.random()-0.5)*8,
      life: 30,
      size: Math.random()*2+0.5,
      decay: 0.04
    }),
    rainbow: () => ({
      hue: Math.random()*360,
      sat: 100,
      lit: 65,
      vx: (Math.random()-0.5)*3,
      vy: (Math.random()-0.5)*3,
      life: 90,
      size: Math.random()*4+1,
      decay: 0.012
    })
  };

  function spawn(x, y, count=5) {
    const fn = MODES[mode];
    for (let i = 0; i < count; i++) {
      const p = fn();
      particles.push({ x, y, alpha: 1, ...p });
    }
  }

  function burst(x, y) {
    spawn(x, y, 60);
  }

  const rect = canvas.getBoundingClientRect();
  canvas.addEventListener('mousemove', (e) => {
    const r = canvas.getBoundingClientRect();
    const cx = e.clientX - r.left, cy = e.clientY - r.top;
    isOver = true;
    spawn(cx, cy, 8);
    lx = cx; ly = cy;
  });
  canvas.addEventListener('mouseleave', () => { isOver = false; });
  canvas.addEventListener('click', (e) => {
    const r = canvas.getBoundingClientRect();
    burst(e.clientX - r.left, e.clientY - r.top);
  });

  $$('.trail-btn[data-mode]').forEach(btn => {
    btn.addEventListener('click', () => {
      $$('.trail-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      mode = btn.dataset.mode;
    });
  });

  $('#trail-clear-btn').addEventListener('click', () => {
    particles = [];
    ctx.clearRect(0, 0, W, H);
  });

  function draw() {
    ctx.fillStyle = 'rgba(3,2,10,0.12)';
    ctx.fillRect(0, 0, W, H);

    for (let i = particles.length-1; i >= 0; i--) {
      const p = particles[i];
      p.x += p.vx;
      p.y += p.vy;
      p.vy += 0.04; // gravity
      p.alpha -= p.decay;
      p.vx *= 0.99;
      if (p.alpha <= 0) { particles.splice(i, 1); continue; }

      ctx.save();
      ctx.globalAlpha = p.alpha;
      const grd = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.size*3);
      grd.addColorStop(0, `hsla(${p.hue},${p.sat}%,${p.lit}%,1)`);
      grd.addColorStop(1, `hsla(${p.hue},${p.sat}%,${p.lit}%,0)`);
      ctx.fillStyle = grd;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size*3, 0, Math.PI*2);
      ctx.fill();
      ctx.restore();
    }

    if (particles.length > 3000) particles.splice(0, particles.length - 3000);
    requestAnimationFrame(draw);
  }
  draw();

  // Idle animation when not hovering
  let autoAngle = 0;
  setInterval(() => {
    if (!isOver) {
      autoAngle += 0.04;
      const x = W/2 + Math.cos(autoAngle)*120;
      const y = H/2 + Math.sin(autoAngle*1.7)*80;
      spawn(x, y, 3);
    }
  }, 30);
})();

